<Window x:Class="FancyButton.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ed="http://schemas.microsoft.com/expression/2010/drawing"
        xmlns:local="clr-namespace:FancyButton"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
        
        <!-- ====================================================================== -->
        <!-- ===================== Gradient Setting =============================== -->
        <!-- ====================================================================== -->
        <LinearGradientBrush x:Key="BlueGradient" StartPoint="0,0.1" EndPoint="1,0.5">
            <GradientStop Color="White" Offset="0.0"/>
            <GradientStop Color="Brown" Offset="2.5"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="3DShadowLightGrey" Color="#c0c0c0"/>
        <SolidColorBrush x:Key="3DShadowMidGrey" Color="#FF9E9C9C"/>
        <SolidColorBrush x:Key="3DShadowDarkGrey" Color="#FF595959"/>
        
        <!-- ====================================================================== -->
        <!-- ===================== Button Gradient ================================ -->
        <!-- ====================================================================== -->
        <Style TargetType="{x:Type Button}" x:Key="3DButtonGradient">
            <Setter Property="Template" >
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}" >
                        <!-- set button area -->
                        <Grid >
                            <!-- set border lines -->
                            <Border x:Name="ShadowBorder" CornerRadius="6" 
                                BorderBrush="{StaticResource 3DShadowMidGrey}" BorderThickness="2,2,2,2"  />
                            <!-- set background here, entire button background with color grandient -->
                            <Grid x:Name="entireButton" Margin="3" 
                                  Background="{StaticResource BlueGradient}" >
                                <ContentPresenter x:Name="d3Text" 
                                HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0"/>
                            </Grid>
                        </Grid>

                        <!-- set visual effected -->
                        <ControlTemplate.Triggers>
                            <!-- show some changes when the mouse moves over to show some notice -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="1,1,2,2" />
                                <Setter TargetName="ShadowBorder" 
                                    Property="BorderBrush" Value="{StaticResource 3DShadowMidGrey}" />
                                <!-- more margin to show white edges -->
                                <Setter TargetName="entireButton" Property="Margin" Value="3,3,3,3" />

                            </Trigger>
                            <!-- show some changes when button pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <!-- back to normal margin -->
                                <Setter TargetName="entireButton" Property="Margin" Value="2,2,1,1" />
                                <!-- move textwords to direction down and right -->
                                <Setter TargetName="d3Text" Property="Margin" Value="2,2,0,0" />

                                <!-- set dark on bottom and right edges-->
                                <Setter TargetName="ShadowBorder" 
                                    Property="BorderBrush" Value="{StaticResource 3DShadowDarkGrey}"/>
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="2,2,1,1" />
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====================================================================== -->
        <!-- ===================== Button Fancy =================================== -->
        <!-- ====================================================================== -->
        <Style TargetType="{x:Type Button}" x:Key="ButtonFancy">
            <Setter Property="Template" >
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}" >

                        <!-- area of whole button -->
                        <Grid >
                            <!-- set border lines -->
                            <Border x:Name="ShadowBorder" CornerRadius="6" 
                                BorderBrush="{StaticResource 3DShadowMidGrey}" 
                                    BorderThickness="2,2,2,2"  />

                            <!-- set background here, background with an image -->
                            <Grid x:Name="entireButton" Margin="3"  >
                                <Grid.Background>
                                    <ImageBrush ImageSource="/FancyButton;component/Images/beach.jpg">
                                    </ImageBrush>
                                </Grid.Background>
                                
                                <!-- set the entire button as three areas -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="45"></ColumnDefinition>
                                    <ColumnDefinition Width="10"></ColumnDefinition>
                                    <ColumnDefinition Width="1.0*"></ColumnDefinition>
                                </Grid.ColumnDefinitions>

                                <!-- first area: build a triangle shape -->
                                <Grid Grid.Column="0" Margin="3,0,0,0">

                                    <ed:RegularPolygon x:Name="triangleRight" InnerRadius="1" 
                                        Margin="0,0,0,0" PointCount="3" Stretch="Fill" Fill="Purple"
                                        Stroke="{StaticResource 3DShadowMidGrey}" 
                                        StrokeThickness="3" RenderTransformOrigin="0.5,0.5" >

                                        <!-- rotate to let it toward the right -->
                                        <ed:RegularPolygon.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleX="0.7" ScaleY="0.5" />
                                                <RotateTransform Angle="90"/>
                                            </TransformGroup>
                                        </ed:RegularPolygon.RenderTransform>
                                    </ed:RegularPolygon>

                                </Grid>

                                <!-- second area: draw a line -->
                                <Grid x:Name="fancyLine" Grid.Column="1">
                                    <Rectangle Width="1.5" VerticalAlignment="Stretch" Fill="Gray" />
                                </Grid>

                                <!-- third area: set the button text -->
                                <Grid x:Name="d3Text" Grid.Column="2" >
                                                                        
                                    <StackPanel Margin="0,5,0,0">
                                        <TextBlock Text="Playing" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            FontFamily="Calibri" FontSize="20" FontWeight="Bold" 
                                            Foreground="Blue" >
                                        </TextBlock>
                                        <TextBlock Text="Duration: 30 min" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            FontFamily="Calibri" FontSize="14" FontWeight="Bold"  
                                            Foreground="Purple" >
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>

                            </Grid>

                        </Grid>
                        <!-- end: area of whole button -->
                        
                        <!-- set visual effected -->
                        <ControlTemplate.Triggers>
                            <!-- set visual 3d when mouse moves over -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="1,1,2,2" />
                                <Setter TargetName="ShadowBorder" 
                                    Property="BorderBrush" Value="{StaticResource 3DShadowMidGrey}" />
                                <!-- more margin to show white edges -->
                                <Setter TargetName="entireButton" Property="Margin" Value="3,3,3,3" />

                            </Trigger>
                            <!-- set visual action when pressing -->
                            <Trigger Property="IsPressed" Value="True">
                                <!-- back to normal margin -->
                                <Setter TargetName="entireButton" Property="Margin" Value="2,2,1,1" />
                                <!-- move textwords to direction down and right -->
                                <Setter TargetName="d3Text" Property="Margin" Value="2,1,0,0" />
                                <Setter TargetName="fancyLine" Property="Margin" Value="3,1,0,0" />
                                <Setter TargetName="triangleRight" Property="Margin" Value="2,1,2,2" />

                                <!-- set dark on bottom and right edges-->
                                <Setter TargetName="ShadowBorder" 
                                    Property="BorderBrush" Value="{StaticResource 3DShadowDarkGrey}"/>
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="2,2,1,1" />
                            </Trigger>

                        </ControlTemplate.Triggers>
                        <!-- end: set visual effected -->

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====================================================================== -->
        <!-- ===================== TextBlock ====================================== -->
        <!-- ====================================================================== -->
        <Style x:Key="ButtonNotice" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Calibri" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="DemiBold" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="1.0*"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="1.0*"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="1.0*"/>
            <RowDefinition Height="1.0*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.0*"></ColumnDefinition>
            <ColumnDefinition Width="1.0*"></ColumnDefinition>
            <ColumnDefinition Width="1.0*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <!-- button 3D gradient -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Button x:Name="Bt3DGradient" HorizontalAlignment="Center" VerticalAlignment="Center" 
                Style="{StaticResource 3DButtonGradient}"
                Width="250" Height="60" Content="3D Gradient" 
                FontFamily="Calibri" FontSize="20" FontWeight="Bold" Foreground="Blue"
                Click="Bt3DGradient_Click" />
        </Grid>

        <Grid Grid.Row="2" Grid.Column="1">
            <TextBlock x:Name="Tb_3dGradient" Text="Button Gradient" 
                Style="{StaticResource ButtonNotice}"
                Foreground="Blue" />
        </Grid>     
        
        <!-- button fancy -->
        <Grid Grid.Row="3" Grid.Column="1">
            <Button x:Name="BtFancy" HorizontalAlignment="Center" VerticalAlignment="Center" 
                Style="{StaticResource ButtonFancy}"
                Width="250" Height="60" Click="BtFancy_Click" />
        </Grid>

        <Grid Grid.Row="4" Grid.Column="1">
            <TextBlock x:Name="Tb_3dFancy" Text="Button Fancy" Style="{StaticResource ButtonNotice}"
                Foreground="Brown" />
        </Grid>

    </Grid>
    
</Window>
