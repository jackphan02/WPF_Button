        <!-- ====================================================================== -->
        <!-- ===================== TextBlock ====================================== -->
        <!-- ====================================================================== -->
        <Style x:Key="TextDemo" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Calibri" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>        
        
    </Window.Resources>

    <!-- ====================================================================== -->
    <!-- ===================== Building buttons =============================== -->
    <!-- ====================================================================== -->

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="70"/>
            
            <RowDefinition Height="100"/>
            <RowDefinition Height="70"/>

            <RowDefinition Height="100"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="1.0*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.0*"></ColumnDefinition>
            <ColumnDefinition Width="1.0*"></ColumnDefinition>
            <ColumnDefinition Width="1.0*"></ColumnDefinition>
            <ColumnDefinition Width="1.0*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <!-- ============================================================================ -->
        <!-- ============================================================================ -->
        <Grid Grid.Row="0" Grid.Column="0">
            <TextBlock Text="3D button round " Style="{StaticResource TextDemo}"
                VerticalAlignment="Bottom" Foreground="Blue" />
        </Grid>

        <!-- ====================== 3D button round ============================ -->
        <!-- ====================== 3D button round ============================ -->
        <Grid Grid.Row="1" Grid.Column="0">
            
            <Button x:Name="Btn3DRound" HorizontalAlignment="Center" VerticalAlignment="Center" 
                Style="{StaticResource 3DButtonRound}"
                Width="120" Height="44" Content="3D round" 
                FontFamily="Calibri" FontSize="20" FontWeight="Bold" Foreground="Blue"
                Click="Btn3DRound_Click"/>   
            
        </Grid>
        
        <!-- ============================================================================ -->        
        <Grid Grid.Row="2" Grid.Column="0">
            <TextBlock Text="3D, border color " Style="{StaticResource TextDemo}"
                VerticalAlignment="Bottom" Foreground="Green" />
        </Grid>

        <!-- ====================== 3D button border color ============================ -->
        <!-- ====================== 3D button border color ============================ -->
        <Grid Grid.Row="3" Grid.Column="0">
                        
            <Button x:Name="BtnBorderColor" HorizontalAlignment="Center" VerticalAlignment="Center" 
                Style="{StaticResource ButtonBorderColor}"
                Width="120" Height="44" Content="Border color"                
                FontFamily="Calibri" FontSize="20" FontWeight="Bold" Foreground="Green"
                Click="BtnBorderColor_Click" />
            
        </Grid>

        <!-- ============================================================================ -->        
        <Grid Grid.Row="4" Grid.Column="0">
            <TextBlock Text="Background color " Style="{StaticResource TextDemo}"
                VerticalAlignment="Bottom" Foreground="Brown" />
        </Grid>

        <!-- ====================== 3D button background color ============================ -->
        <!-- ====================== 3D button background color ============================ -->
        <Grid Grid.Row="5" Grid.Column="0">

            <Button x:Name="BtnBackGroundColor" HorizontalAlignment="Center" VerticalAlignment="Center" 
                Style="{StaticResource ButtonBackgroundColor}"
                Width="120" Height="44" Content="Back. color" FontFamily="Calibri"                 
                FontSize="20" FontWeight="Bold" Foreground="Green"
                Click="BtnBackGroundColor_Click" />

        </Grid>

        <!-- ============================================================================ -->
        <Grid Grid.Row="0" Grid.Column="1">
            <TextBlock Style="{StaticResource TextDemo}"
                VerticalAlignment="Bottom" Foreground="Blue" >
                Light color
            </TextBlock>
        </Grid>
        <!-- ====================== Light button ========================================= -->
        <!-- ====================== Light button ========================================= -->
        <Grid Grid.Row="1" Grid.Column="1">

            <Button x:Name="BtnLightColor" HorizontalAlignment="Center" VerticalAlignment="Center" 
                Style="{StaticResource 3DButtonLight}"
                Width="120" Height="44" Content="Light"                     
                FontFamily="Calibri" FontSize="20" FontWeight="Bold" Foreground="White"
                Click="BtnLightColor_Click" />

        </Grid>

        <!-- ============================================================================ -->
        <Grid Grid.Row="2" Grid.Column="1">
            <TextBlock Style="{StaticResource TextDemo}"
                VerticalAlignment="Bottom" Foreground="Blue" >
                Dark color
            </TextBlock>
        </Grid>

        <!-- ====================== Dark button ========================================== -->
        <!-- ====================== Dark button ========================================== -->
        <Grid Grid.Row="3" Grid.Column="1">

            <Button x:Name="BtnDarkColor" HorizontalAlignment="Center" VerticalAlignment="Center" 
                Style="{StaticResource 3DButtonDark}"
                Width="120" Height="44" Content="Dark"                     
                FontFamily="Calibri" FontSize="20" FontWeight="Bold" Foreground="White"
                Click="BtnDarkColor_Click" />

        </Grid>

        <!-- ============================================================================ -->        
        <Grid Grid.Row="0" Grid.Column="2">
            <TextBlock Style="{StaticResource TextDemo}"
                VerticalAlignment="Bottom" Foreground="Black" >
                Toogle button<LineBreak />
                Start/Stop
            </TextBlock>
        </Grid>         
        <!-- ====================== Toggel button Start/Stop ============================ -->
        <!-- ====================== Toggel button Start/Stop ============================ -->         
        <Grid Grid.Row="1" Grid.Column="2">
            <ToggleButton Width="120" Height="44" Style="{StaticResource BtnToggleStartStop}" 
                          FontFamily="Calibri" FontSize="20" FontWeight="Bold"
                          Checked="BtnStart_Click" Unchecked="BtnStop_Click" />

        </Grid>

        <!-- ============================================================================ -->        
        <Grid Grid.Row="2" Grid.Column="2">
            <TextBlock Style="{StaticResource TextDemo}"
                VerticalAlignment="Bottom" Foreground="Blue" >
                Toogle button ON/OFF
            </TextBlock>
        </Grid>

        <!-- ====================== Toggel button ON/OFF ================================ -->
        <!-- ====================== Toggel button ON/OFF ================================ -->        
        <!-- 3d toggle button, On/Off-->
        <Grid Grid.Row="3" Grid.Column="2">
            <ToggleButton Width="120" Height="44" Style="{StaticResource BtnToggleOnOff}" 
                          FontFamily="Calibri" FontSize="20" FontWeight="Bold"
                          Checked="BtnON_Click" Unchecked="BtnOFF_Click" />
        </Grid>
        
        <!-- ============================================================================ -->
        <Grid Grid.Row="0" Grid.Column="3">
            <TextBlock Style="{StaticResource TextDemo}"
                VerticalAlignment="Bottom" Foreground="Blue" >
                Button with image
            </TextBlock>
        </Grid>
        
        <!-- ====================== Toggel button with image ============================ -->
        <!-- ====================== Toggel button with image ============================ -->
        <Grid Grid.Row="5" Grid.Column="2">
            <ToggleButton Width="120" Height="44" Style="{StaticResource BtnToggleOnOffImage}" 
                          FontFamily="Calibri" FontSize="20" FontWeight="Bold"
                          Checked="BtnOnImag_Click" Unchecked="BtnOffImag_Click" />
        </Grid>

        <!-- ============================================================================ -->
        <Grid Grid.Row="4" Grid.Column="2">
            <TextBlock Style="{StaticResource TextDemo}"
                VerticalAlignment="Bottom" Foreground="Green" >
                Toogle button<LineBreak />
                On/Off imgages
            </TextBlock>
        </Grid>

        <!-- ====================== Button with image =================================== -->
        <!-- ====================== Button with image =================================== -->
        <Grid Grid.Row="1" Grid.Column="3">

