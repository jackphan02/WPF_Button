                        <ControlTemplate.Triggers>

                            <!-- when start, default -->
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="Blue" />
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <Image Source="/ButtonPracice01;component/Images/SwitchOn.jpg" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <!-- when stop -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="Black" />

                                <Setter Property="Content">
                                    <Setter.Value>
                                        <Image Source="/ButtonPracice01;component/Images/SwitchOff.jpg" />
                                    </Setter.Value>
                                </Setter>

                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="1,1,2,2" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="2,2,1,1" />

                                <!-- move textwords to direction down and right -->
                                <Setter TargetName="d3Text" Property="Margin" Value="3,3,0,0" />

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
