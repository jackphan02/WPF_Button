<Window x:Class="ButtonPracice01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ButtonPracice01"
        mc:Ignorable="d"
        Title="WPF Buttons" Height="600" Width="800" FontWeight="Bold" FontSize="16">
    <Window.Resources>

        <!-- ====================================================================== -->
        <!-- ======================== 3DButtonRound =============================== -->
        <!-- ====================================================================== -->
        <SolidColorBrush x:Key="3DShadowLightGrey" Color="#c0c0c0"/>
        <SolidColorBrush x:Key="3DShadowMidGrey"   Color="#FF9E9C9C"/>
        <SolidColorBrush x:Key="3DShadowDarkGrey"  Color="#FF595959"/>
        
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <Style TargetType="{x:Type Button}" x:Key="3DButtonRound">
            <Setter Property="Template" >
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}" >
                        
                        <Grid >
                            <Border x:Name="ShadowBorder" CornerRadius="6" 
                                 BorderBrush="{StaticResource 3DShadowMidGrey}" BorderThickness="2,2,2,2"  />
                            <!-- set background here, entire button background very light grey, #A1EFEEEE -->
                            <Grid x:Name="entireButton" Margin="3" Background="#A1EFEEEE" >
                                <ContentPresenter x:Name="d3Text" Margin="0,0,0,0"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="1,1,2,2" />
                                <Setter TargetName="ShadowBorder" Property="BorderBrush" 
                                        Value="{StaticResource 3DShadowMidGrey}" />
                                <!-- more margin to show white edges -->
                                <Setter TargetName="entireButton" Property="Margin" Value="3,3,3,3" />

                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <!-- back to normal margin -->
                                <Setter TargetName="entireButton" Property="Margin" Value="2,2,1,1" />
                                <!-- move textwords to direction down and right -->
                                <Setter TargetName="d3Text" Property="Margin" Value="2,2,0,0" />

                                <!-- set dark on bottom and right edges-->
                                <Setter TargetName="ShadowBorder" Property="BorderBrush" 
                                        Value="{StaticResource 3DShadowDarkGrey}"/>
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="2,2,1,1" />
                            </Trigger>

                        </ControlTemplate.Triggers>
                        
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <Style TargetType="{x:Type Button}" x:Key="ButtonBorderColor">
            <Setter Property="Template" >
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}" >
                        
                        <Grid >
                            <!-- set border color here -->
                            <Border x:Name="ShadowBorder" CornerRadius="6" BorderBrush="Blue" 
                                    BorderThickness="2,2,2,2"  />
                            <!-- set background here, entire button background very light grey, #A1EFEEEE -->
                            <Grid x:Name="entireButton" Margin="3" Background="#A1EFEEEE" >
                                <ContentPresenter x:Name="d3Text" 
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="1,1,2,2" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="2,2,1,1" />

                                <!-- move textwords to direction down and right -->
                                <Setter TargetName="d3Text" Property="Margin" Value="3,3,0,0" />

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <Style TargetType="{x:Type Button}" x:Key="ButtonBackgroundColor">
            <Setter Property="Template" >
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        
                        <Grid >
                            <!-- set border color here -->
                            <Border x:Name="ShadowBorder" CornerRadius="6" BorderBrush="Blue" 
                                    BorderThickness="2,2,2,2"  />
                            <!-- set background here, entire button background very light grey, #A1EFEEEE -->
                            <Grid x:Name="entireButton" Margin="2" Background="LightCyan" >
                                <ContentPresenter x:Name="d3Text" 
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="1,1,2,2" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="2,2,1,1" />

                                <!-- move textwords to direction down and right -->
                                <Setter TargetName="d3Text" Property="Margin" Value="3,3,0,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <Style TargetType="{x:Type Button}" x:Key="3DButtonLight">
            <Setter Property="Template" >
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        
                        <!-- area of button -->
                        <Grid >
                            <!-- set one outside border color here -->
                            <Border x:Name="ShadowBorder" CornerRadius="6" 
                                    BorderBrush="Green" BorderThickness="3"/>
                            <!-- set another border for entire inside, 
                                         with margin the same BortherThickness -->
                            <!-- set background here, entire button background -->
                            <Border CornerRadius="4" Background="LightPink" Margin="3,3,3,3" >
                                <Grid x:Name="entireButton">
                                    <ContentPresenter x:Name="d3Text" HorizontalAlignment="Center" 
                                        VerticalAlignment="Center" Margin="0,0,0,0"/>
                                </Grid>
                            </Border>
                            
                        </Grid>

                        <!-- set actions -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="1,1,2,2" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="2,2,1,1" />

                                <!-- move textwords to direction down 3, and right 3 -->
                                <Setter TargetName="d3Text" Property="Margin" Value="3,3,0,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <Style TargetType="{x:Type Button}" x:Key="3DButtonDark">
            <Setter Property="Template" >
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">

                        <!-- area of button -->
                        <Grid >
                            <!-- set one outside border color here -->
                            <Border x:Name="ShadowBorder" CornerRadius="6" 
                                    BorderBrush="Blue" BorderThickness="3"/>
                            <!-- set another border for entire inside,  
                                         with margin the same BortherThickness -->
                            <!-- set background here, entire button background -->
                            <Border CornerRadius="4" Background="Blue" Margin="3,3,3,3" >

                                <Grid x:Name="entireButton">
                                    <ContentPresenter x:Name="d3Text" HorizontalAlignment="Center" 
                                        VerticalAlignment="Center" Margin="0,0,0,0"/>
                                </Grid>
                            </Border>

                        </Grid>

                        <!-- set actions -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="1,1,2,2" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="2,2,1,1" />

                                <!-- move textwords to direction down 3, and right 3 -->
                                <Setter TargetName="d3Text" Property="Margin" Value="3,3,0,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <Style TargetType="{x:Type ToggleButton}" x:Key="BtnToggleStartStop">
            <Setter Property="Template" >
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}" >

                        <Grid >
                            <Border x:Name="ShadowBorder" CornerRadius="6" 
                                BorderBrush="{StaticResource 3DShadowMidGrey}" BorderThickness="2,2,2,2"/>
                            <!--set background here, entire button background very light grey, #A1EFEEEE-->
                            <Grid x:Name="entireButton" Background="#A1EFEEEE" Margin="3" >
                                <ContentPresenter x:Name="d3Text" 
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- when start, default -->
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Background" Value="Yellow" />
                                <Setter Property="Foreground" Value="Black" />
                                <Setter Property="Content" Value="Toggle Start"/>
                            </Trigger>
                            <!-- when stop -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="LightGray" />
                                <Setter Property="Foreground" Value="Red" />
                                <Setter Property="Content" Value="Toggle Stop"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="1,1,2,2"/>
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderBrush" Value="{StaticResource 3DShadowMidGrey}" />
                                <!-- more margin to show white edges -->
                                <Setter TargetName="entireButton" Property="Margin" Value="3,3,3,3" />

                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <!-- back to normal margin -->
                                <Setter TargetName="entireButton" Property="Margin" Value="2,2,1,1" />
                                <!-- move textwords to direction down and right -->
                                <Setter TargetName="d3Text" Property="Margin" Value="2,2,0,0" />

                                <!-- set dark on bottom and right edges-->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderBrush" Value="{StaticResource 3DShadowDarkGrey}"/>
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="2,2,1,1" />
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <Style TargetType="{x:Type ToggleButton}" x:Key="BtnToggleOnOff">
            <Setter Property="Template" >
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}" >
                        <Grid >
                            <!-- set border color here -->
                            <Border x:Name="ShadowBorder" CornerRadius="6" 
                                    BorderBrush="Blue" BorderThickness="2"/>
                            <!--set background here, entire button background very light grey, #A1EFEEEE-->
                            <Grid x:Name="entireButton" Margin="3" Background="#A1EFEEEE" >
                                <ContentPresenter x:Name="d3Text" 
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>

                            <!-- when start, default -->
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="Blue" />
                                <Setter Property="Content" Value="Toggle ON"/>
                            </Trigger>
                            <!-- when stop -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="Red" />
                                <Setter Property="Content" Value="Toggle OFF"/>
                            </Trigger>
                            
                            <Trigger Property="IsMouseOver" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="1,1,2,2" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <!-- change border thickness to show visual effect -->
                                <Setter TargetName="ShadowBorder" 
                                        Property="BorderThickness" Value="2,2,1,1" />

                                <!-- move textwords to direction down and right -->
                                <Setter TargetName="d3Text" Property="Margin" Value="3,3,0,0" />

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <!-- ====================================================================== -->
        <Style TargetType="{x:Type ToggleButton}" x:Key="BtnToggleOnOffImage">
            <Setter Property="Template" >
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}" >
                        <Grid >
                            <!-- set border color here -->
                            <Border x:Name="ShadowBorder" CornerRadius="6" 
                                    BorderBrush="Blue" BorderThickness="2,2,2,2"/>
                            <!-- set background here, entire button background very light grey, #A1EFEEEE -->
                            <Grid x:Name="entireButton" Margin="3" Background="#A1EFEEEE" >
                                <ContentPresenter x:Name="d3Text" 
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
